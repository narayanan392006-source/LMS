<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Library Management System | Professional Edition</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Poppins', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 30px 20px;
            position: relative;
        }

        /* Animated background effect */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><text x="10" y="30" font-size="12" fill="rgba(255,255,255,0.03)">📚</text><text x="70" y="60" font-size="14" fill="rgba(255,255,255,0.03)">📖</text><text x="30" y="85" font-size="10" fill="rgba(255,255,255,0.03)">📕</text><text x="85" y="20" font-size="16" fill="rgba(255,255,255,0.03)">📘</text></svg>');
            background-repeat: repeat;
            pointer-events: none;
            z-index: 0;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        /* Header Section */
        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .header h1 {
            font-size: 2.5rem;
            background: linear-gradient(135deg, #fff 0%, #e0e0e0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 10px;
            letter-spacing: -0.5px;
        }

        .header p {
            color: rgba(255,255,255,0.8);
            font-size: 1rem;
        }

        .stats-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            cursor: pointer;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 40px rgba(0,0,0,0.15);
        }

        .stat-card .stat-icon {
            font-size: 2rem;
            margin-bottom: 10px;
        }

        .stat-card .stat-number {
            font-size: 2rem;
            font-weight: bold;
            color: #667eea;
        }

        .stat-card .stat-label {
            color: #666;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Menu Buttons */
        .menu {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            justify-content: center;
            margin-bottom: 30px;
        }

        .menu button {
            background: rgba(255,255,255,0.95);
            border: none;
            padding: 12px 24px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            color: #4a5568;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .menu button:hover {
            transform: translateY(-2px);
            background: white;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            color: #667eea;
        }

        .menu button:active {
            transform: translateY(0);
        }

        /* Sections (Forms) */
        .section {
            background: white;
            border-radius: 24px;
            padding: 28px;
            margin-bottom: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .section h3 {
            font-size: 1.5rem;
            color: #2d3748;
            margin-bottom: 20px;
            border-left: 4px solid #667eea;
            padding-left: 15px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #4a5568;
            font-size: 0.9rem;
        }

        .form-group input, .form-group select {
            width: 100%;
            max-width: 400px;
            padding: 12px 16px;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            font-size: 1rem;
            transition: all 0.3s ease;
            font-family: inherit;
        }

        .form-group input:focus, .form-group select:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.1);
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 12px 28px;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(102,126,234,0.4);
        }

        .btn-danger {
            background: linear-gradient(135deg, #f56565 0%, #ed64a6 100%);
        }

        /* Output / Display Area */
        .output, .display-area {
            background: white;
            border-radius: 24px;
            padding: 24px;
            margin-top: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            overflow-x: auto;
        }

        /* Table Styles */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        th {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 14px;
            text-align: left;
            font-weight: 600;
        }

        td {
            padding: 12px 14px;
            border-bottom: 1px solid #e2e8f0;
            color: #4a5568;
        }

        tr:hover {
            background: #f7fafc;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-available {
            background: #c6f6d5;
            color: #22543d;
        }

        .status-borrowed {
            background: #fed7d7;
            color: #742a2a;
        }

        /* Browser Card */
        .browser-card {
            text-align: center;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            padding: 40px;
            border-radius: 24px;
        }

        .browser-card .book-detail {
            background: white;
            padding: 30px;
            border-radius: 20px;
            margin: 20px 0;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        /* Save Indicator */
        .save-indicator {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
            color: white;
            padding: 12px 24px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 600;
            display: none;
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
            z-index: 1000;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from {
                transform: translateX(100px);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* Responsive */
        @media (max-width: 768px) {
            body {
                padding: 20px 15px;
            }

            .header h1 {
                font-size: 1.8rem;
            }

            .menu button {
                padding: 10px 18px;
                font-size: 12px;
            }

            .section {
                padding: 20px;
            }

            th, td {
                padding: 8px 10px;
                font-size: 12px;
            }

            .stats-cards {
                grid-template-columns: repeat(2, 1fr);
                gap: 12px;
            }

            .stat-card {
                padding: 12px;
            }

            .stat-card .stat-number {
                font-size: 1.5rem;
            }
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb {
            background: #667eea;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #764ba2;
        }
    </style>
</head>
<body>

<div class="container">
    <!-- Header -->
    <div class="header">
        <h1>📚 Library Management System</h1>
        <p>Professional Edition | Circular Linked List Implementation</p>
    </div>

    <!-- Stats Cards -->
    <div class="stats-cards">
        <div class="stat-card" onclick="showAllBooks()">
            <div class="stat-icon">📖</div>
            <div class="stat-number" id="totalBooks">0</div>
            <div class="stat-label">Total Books</div>
        </div>
        <div class="stat-card" onclick="showAvailableBooks()">
            <div class="stat-icon">✅</div>
            <div class="stat-number" id="availableBooks">0</div>
            <div class="stat-label">Available</div>
        </div>
        <div class="stat-card" onclick="showBorrowedBooks()">
            <div class="stat-icon">📤</div>
            <div class="stat-number" id="borrowedBooks">0</div>
            <div class="stat-label">Borrowed</div>
        </div>
        <div class="stat-card" onclick="showWaitingList()">
            <div class="stat-icon">⏳</div>
            <div class="stat-number" id="waitingCount">0</div>
            <div class="stat-label">Waiting List</div>
        </div>
    </div>

    <!-- Menu Buttons -->
    <div class="menu">
        <button onclick="showSection('add')">➕ Add Book</button>
        <button onclick="showSection('remove')">❌ Remove Book</button>
        <button onclick="showSection('search')">🔍 Search Book</button>
        <button onclick="showSection('borrow')">📖 Borrow Book</button>
        <button onclick="showSection('return')">🔄 Return Book</button>
        <button onclick="showAllBooks()">📋 Display All Books</button>
        <button onclick="showBrowser()">🔁 Browse Catalog</button>
        <button onclick="loadSampleData()">📚 Sample Data</button>
        <button onclick="clearAllData()" style="background:#f56565; color:white;">🗑️ Clear All</button>
    </div>

    <!-- Add Book Section -->
    <div id="add" class="section" style="display:none">
        <h3>➕ Add New Book</h3>
        <div class="form-group"><label>Book Title</label><input type="text" id="title" placeholder="Enter book title"></div>
        <div class="form-group"><label>Author Name</label><input type="text" id="author" placeholder="Enter author name"></div>
        <div class="form-group"><label>Genre</label><input type="text" id="genre" placeholder="Fiction, Science, etc."></div>
        <button class="btn-primary" onclick="addBook()">Add Book</button>
        <div id="addOutput" class="output" style="margin-top:15px"></div>
    </div>

    <!-- Remove Book Section -->
    <div id="remove" class="section" style="display:none">
        <h3>❌ Remove Book</h3>
        <div class="form-group"><label>Book ID</label><input type="number" id="removeId" placeholder="Enter Book ID"></div>
        <button class="btn-primary" onclick="removeBook()">Remove Book</button>
        <div id="removeOutput" class="output" style="margin-top:15px"></div>
    </div>

    <!-- Search Section -->
    <div id="search" class="section" style="display:none">
        <h3>🔍 Search Book</h3>
        <div class="form-group"><label>Search By</label>
            <select id="searchType">
                <option value="id">Book ID</option>
                <option value="title">Title</option>
                <option value="author">Author</option>
            </select>
        </div>
        <div class="form-group"><label>Search Term</label><input type="text" id="searchTerm" placeholder="Enter search value"></div>
        <button class="btn-primary" onclick="searchBook()">Search</button>
        <div id="searchOutput" class="output" style="margin-top:15px"></div>
    </div>

    <!-- Borrow Section -->
    <div id="borrow" class="section" style="display:none">
        <h3>📖 Borrow Book</h3>
        <div class="form-group"><label>Book ID</label><input type="number" id="borrowId" placeholder="Enter Book ID"></div>
        <div class="form-group"><label>Your Name</label><input type="text" id="borrowerName" placeholder="Enter your name"></div>
        <button class="btn-primary" onclick="borrowBook()">Borrow Book</button>
        <div id="borrowOutput" class="output" style="margin-top:15px"></div>
    </div>

    <!-- Return Section -->
    <div id="return" class="section" style="display:none">
        <h3>🔄 Return Book</h3>
        <div class="form-group"><label>Book ID</label><input type="number" id="returnId" placeholder="Enter Book ID"></div>
        <button class="btn-primary" onclick="returnBook()">Return Book</button>
        <div id="returnOutput" class="output" style="margin-top:15px"></div>
    </div>

    <!-- Main Display Area -->
    <div id="displayArea" class="display-area">
        <p style="text-align:center; color:#718096;">✨ Welcome to your Library Management System ✨<br>Click any button above to get started</p>
    </div>
</div>

<div id="saveIndicator" class="save-indicator">💾 Data Saved</div>

<script>
    // ---------- DATA STRUCTURES ----------
    class Book {
        constructor(id, title, author, genre) {
            this.bookID = id;
            this.title = title;
            this.author = author;
            this.genre = genre || "General";
            this.isAvailable = true;
        }
    }

    class DoublyNode {
        constructor(book) {
            this.book = book;
            this.next = null;
            this.prev = null;
        }
    }

    class DoublyCircularList {
        constructor() {
            this.head = null;
            this.current = null;
            this.size = 0;
        }

        insert(book) {
            const newNode = new DoublyNode(book);
            if (!this.head) {
                this.head = newNode;
                this.head.next = this.head;
                this.head.prev = this.head;
                this.current = this.head;
            } else {
                const tail = this.head.prev;
                tail.next = newNode;
                newNode.prev = tail;
                newNode.next = this.head;
                this.head.prev = newNode;
            }
            this.size++;
        }

        deleteById(bookID) {
            if (!this.head) return false;
            let node = this.head;
            do {
                if (node.book.bookID === bookID) {
                    if (this.size === 1) {
                        this.head = null;
                        this.current = null;
                    } else {
                        node.prev.next = node.next;
                        node.next.prev = node.prev;
                        if (node === this.head) this.head = node.next;
                        if (node === this.current) this.current = node.next;
                    }
                    this.size--;
                    return true;
                }
                node = node.next;
            } while (node !== this.head);
            return false;
        }

        searchById(bookID) {
            if (!this.head) return null;
            let node = this.head;
            do {
                if (node.book.bookID === bookID) return node.book;
                node = node.next;
            } while (node !== this.head);
            return null;
        }

        searchByTitle(partialTitle) {
            if (!this.head) return null;
            let node = this.head;
            do {
                if (node.book.title.toLowerCase().includes(partialTitle.toLowerCase())) return node.book;
                node = node.next;
            } while (node !== this.head);
            return null;
        }

        searchByAuthor(partialAuthor) {
            const results = [];
            if (!this.head) return results;
            let node = this.head;
            do {
                if (node.book.author.toLowerCase().includes(partialAuthor.toLowerCase())) {
                    results.push(node.book);
                }
                node = node.next;
            } while (node !== this.head);
            return results;
        }

        getAllBooks() {
            const books = [];
            if (!this.head) return books;
            let node = this.head;
            do {
                books.push(node.book);
                node = node.next;
            } while (node !== this.head);
            return books;
        }

        getAvailableBooks() {
            return this.getAllBooks().filter(b => b.isAvailable);
        }

        getBorrowedBooks() {
            return this.getAllBooks().filter(b => !b.isAvailable);
        }

        next() {
            if (this.current) this.current = this.current.next;
        }

        prev() {
            if (this.current) this.current = this.current.prev;
        }
        
        loadFromBooks(books) {
            if (!books || books.length === 0) return;
            for (let bookData of books) {
                const book = new Book(bookData.bookID, bookData.title, bookData.author, bookData.genre);
                book.isAvailable = bookData.isAvailable;
                this.insert(book);
            }
        }
    }

    class SinglyNode {
        constructor(book, userName) {
            this.book = book;
            this.userName = userName;
            this.next = null;
        }
    }

    class SinglyCircularList {
        constructor() {
            this.tail = null;
            this.size = 0;
        }

        enqueue(book, userName) {
            const newNode = new SinglyNode(book, userName);
            if (!this.tail) {
                this.tail = newNode;
                this.tail.next = this.tail;
            } else {
                newNode.next = this.tail.next;
                this.tail.next = newNode;
                this.tail = newNode;
            }
            this.size++;
        }

        dequeueSpecificBook(bookID) {
            if (!this.tail) return null;
            let prev = this.tail;
            let current = this.tail.next;
            let found = null;
            do {
                if (current.book.bookID === bookID) {
                    found = current.userName;
                    if (this.size === 1) {
                        this.tail = null;
                    } else {
                        prev.next = current.next;
                        if (current === this.tail) {
                            this.tail = prev;
                        }
                    }
                    this.size--;
                    break;
                }
                prev = current;
                current = current.next;
            } while (current !== this.tail.next);
            return found;
        }

        getAllEntries() {
            const entries = [];
            if (!this.tail) return entries;
            let current = this.tail.next;
            do {
                entries.push({ book: current.book, userName: current.userName });
                current = current.next;
            } while (current !== this.tail.next);
            return entries;
        }
        
        loadFromEntries(entries) {
            if (!entries || entries.length === 0) return;
            for (let entry of entries) {
                const book = new Book(entry.book.bookID, entry.book.title, entry.book.author, entry.book.genre);
                book.isAvailable = entry.book.isAvailable;
                this.enqueue(book, entry.userName);
            }
        }
    }

    class LibraryManager {
        constructor() {
            this.catalog = new DoublyCircularList();
            this.waitingList = new SinglyCircularList();
            this.nextBookID = 1001;
        }

        addBook(title, author, genre) {
            const newBook = new Book(this.nextBookID++, title, author, genre);
            this.catalog.insert(newBook);
            this.saveToLocalStorage();
            this.updateStats();
            return newBook;
        }

        removeBook(bookID) {
            const book = this.catalog.searchById(bookID);
            if (!book) return false;
            const result = this.catalog.deleteById(bookID);
            if (result) {
                this.saveToLocalStorage();
                this.updateStats();
            }
            return result;
        }

        searchById(bookID) {
            return this.catalog.searchById(bookID);
        }

        searchByTitle(partialTitle) {
            return this.catalog.searchByTitle(partialTitle);
        }

        searchByAuthor(partialAuthor) {
            return this.catalog.searchByAuthor(partialAuthor);
        }

        borrowBook(bookID, userName) {
            const book = this.catalog.searchById(bookID);
            if (!book) return { success: false, message: `❌ Book ID ${bookID} not found.` };
            if (book.isAvailable) {
                book.isAvailable = false;
                this.saveToLocalStorage();
                this.updateStats();
                return { success: true, message: `✅ "${book.title}" issued to ${userName}. Return within 14 days.` };
            } else {
                this.waitingList.enqueue(book, userName);
                this.saveToLocalStorage();
                this.updateStats();
                return { success: true, message: `⏳ Book currently borrowed. Added to waiting list (Position: ${this.waitingList.size})` };
            }
        }

        returnBook(bookID) {
            const book = this.catalog.searchById(bookID);
            if (!book) return { success: false, message: `❌ Book ID ${bookID} not found.` };
            if (!book.isAvailable) {
                const nextUser = this.waitingList.dequeueSpecificBook(bookID);
                if (nextUser) {
                    this.saveToLocalStorage();
                    this.updateStats();
                    return { success: true, message: `✅ Book returned. "${book.title}" automatically issued to ${nextUser}.` };
                } else {
                    book.isAvailable = true;
                    this.saveToLocalStorage();
                    this.updateStats();
                    return { success: true, message: `✅ Book returned. "${book.title}" is now available.` };
                }
            } else {
                return { success: false, message: `⚠️ "${book.title}" was not borrowed.` };
            }
        }

        getAllBooks() {
            return this.catalog.getAllBooks();
        }

        getAvailableBooks() {
            return this.catalog.getAvailableBooks();
        }

        getBorrowedBooks() {
            return this.catalog.getBorrowedBooks();
        }

        getWaitingList() {
            return this.waitingList.getAllEntries();
        }

        getWaitingCount() {
            return this.waitingList.size;
        }

        loadSampleData() {
            const samples = [
                ["Data Structures & Algorithms", "Thomas Cormen", "Computer Science"],
                ["Clean Code", "Robert C. Martin", "Programming"],
                ["The Pragmatic Programmer", "David Thomas", "Programming"],
                ["Design Patterns", "Gang of Four", "Software Engineering"]
            ];
            for (let [title, author, genre] of samples) {
                this.addBook(title, author, genre);
            }
        }
        
        saveToLocalStorage() {
            const data = {
                books: this.getAllBooks(),
                waitingList: this.getWaitingList(),
                nextBookID: this.nextBookID
            };
            localStorage.setItem('libraryData', JSON.stringify(data));
            this.showSaveIndicator();
        }
        
        loadFromLocalStorage() {
            const saved = localStorage.getItem('libraryData');
            if (saved) {
                const data = JSON.parse(saved);
                this.catalog = new DoublyCircularList();
                this.waitingList = new SinglyCircularList();
                this.catalog.loadFromBooks(data.books);
                this.waitingList.loadFromEntries(data.waitingList);
                this.nextBookID = data.nextBookID;
                this.updateStats();
                return true;
            }
            return false;
        }
        
        clearAllData() {
            localStorage.removeItem('libraryData');
            this.catalog = new DoublyCircularList();
            this.waitingList = new SinglyCircularList();
            this.nextBookID = 1001;
            this.saveToLocalStorage();
            this.updateStats();
        }
        
        updateStats() {
            document.getElementById('totalBooks').innerText = this.catalog.size;
            document.getElementById('availableBooks').innerText = this.getAvailableBooks().length;
            document.getElementById('borrowedBooks').innerText = this.getBorrowedBooks().length;
            document.getElementById('waitingCount').innerText = this.waitingList.size;
        }
        
        showSaveIndicator() {
            const indicator = document.getElementById('saveIndicator');
            indicator.style.display = 'block';
            setTimeout(() => {
                indicator.style.display = 'none';
            }, 1500);
        }
    }

    // ---------- GLOBAL INSTANCE ----------
    const lib = new LibraryManager();
    
    // Load saved data on startup
    const loaded = lib.loadFromLocalStorage();
    if (!loaded || lib.getAllBooks().length === 0) {
        lib.loadSampleData();
    }
    lib.updateStats();

    // ---------- UI FUNCTIONS ----------
    function showSection(sectionId) {
        document.querySelectorAll('.section').forEach(sec => sec.style.display = 'none');
        document.getElementById(sectionId).style.display = 'block';
        document.getElementById(sectionId + 'Output').innerHTML = '';
        document.getElementById('displayArea').innerHTML = '';
    }

    function addBook() {
        const title = document.getElementById('title').value.trim();
        const author = document.getElementById('author').value.trim();
        const genre = document.getElementById('genre').value.trim();
        if (!title || !author) {
            document.getElementById('addOutput').innerHTML = '<span style="color:red">❌ Title and Author are required.</span>';
            return;
        }
        const book = lib.addBook(title, author, genre);
        document.getElementById('addOutput').innerHTML = `<span style="color:green">✅ Book added! ID: ${book.bookID}, Title: "${book.title}"</span>`;
        document.getElementById('title').value = '';
        document.getElementById('author').value = '';
        document.getElementById('genre').value = '';
    }

    function removeBook() {
        const id = parseInt(document.getElementById('removeId').value);
        if (isNaN(id)) {
            document.getElementById('removeOutput').innerHTML = '<span style="color:red">❌ Enter valid Book ID.</span>';
            return;
        }
        const success = lib.removeBook(id);
        if (success) {
            document.getElementById('removeOutput').innerHTML = `<span style="color:green">✅ Book ID ${id} removed successfully.</span>`;
        } else {
            document.getElementById('removeOutput').innerHTML = `<span style="color:red">❌ Book ID ${id} not found.</span>`;
        }
        document.getElementById('removeId').value = '';
    }

    function searchBook() {
        const type = document.getElementById('searchType').value;
        const term = document.getElementById('searchTerm').value.trim();
        if (!term) {
            document.getElementById('searchOutput').innerHTML = '<span style="color:red">❌ Enter search term.</span>';
            return;
        }
        let result = null;
        let resultsArray = null;
        if (type === 'id') {
            const id = parseInt(term);
            if (isNaN(id)) {
                document.getElementById('searchOutput').innerHTML = '<span style="color:red">❌ Enter numeric ID.</span>';
                return;
            }
            result = lib.searchById(id);
            if (result) {
                displaySingleBook(result, document.getElementById('searchOutput'));
            } else {
                document.getElementById('searchOutput').innerHTML = '<span style="color:red">❌ Book not found.</span>';
            }
        } else if (type === 'title') {
            result = lib.searchByTitle(term);
            if (result) {
                displaySingleBook(result, document.getElementById('searchOutput'));
            } else {
                document.getElementById('searchOutput').innerHTML = '<span style="color:red">❌ Book not found.</span>';
            }
        } else if (type === 'author') {
            resultsArray = lib.searchByAuthor(term);
            if (resultsArray.length) {
                displayBookList(resultsArray, document.getElementById('searchOutput'), `📚 Books by "${term}":`);
            } else {
                document.getElementById('searchOutput').innerHTML = '<span style="color:red">❌ No books found by that author.</span>';
            }
        }
    }

    function displaySingleBook(book, outputDiv) {
        const statusClass = book.isAvailable ? 'status-available' : 'status-borrowed';
        const statusText = book.isAvailable ? 'Available' : 'Borrowed';
        outputDiv.innerHTML = `
            <div style="border:2px solid #e2e8f0; padding:20px; border-radius:16px;">
                <h4>📖 Book Details</h4>
                <p><strong>ID:</strong> ${book.bookID}</p>
                <p><strong>Title:</strong> "${book.title}"</p>
                <p><strong>Author:</strong> ${book.author}</p>
                <p><strong>Genre:</strong> ${book.genre}</p>
                <p><strong>Status:</strong> <span class="status-badge ${statusClass}">${statusText}</span></p>
            </div>
        `;
    }

    function displayBookList(books, outputDiv, title) {
        if (!books.length) {
            outputDiv.innerHTML = '<span style="color:red">❌ No books to display.</span>';
            return;
        }
        let html = `<h4>${title}</h4><table>`;
        html += `<thead><tr><th>ID</th><th>Title</th><th>Author</th><th>Genre</th><th>Status</th></tr></thead><tbody>`;
        books.forEach(book => {
            const statusClass = book.isAvailable ? 'status-available' : 'status-borrowed';
            const statusText = book.isAvailable ? 'Available' : 'Borrowed';
            html += `<tr>
                        <td>${book.bookID}</td>
                        <td><strong>${book.title}</strong></td>
                        <td>${book.author}</td>
                        <td>${book.genre}</td>
                        <td><span class="status-badge ${statusClass}">${statusText}</span></td>
                     </tr>`;
        });
        html += `</tbody></table>`;
        outputDiv.innerHTML = html;
    }

    function borrowBook() {
        const id = parseInt(document.getElementById('borrowId').value);
        const name = document.getElementById('borrowerName').value.trim();
        if (isNaN(id) || !name) {
            document.getElementById('borrowOutput').innerHTML = '<span style="color:red">❌ Enter valid Book ID and your name.</span>';
            return;
        }
        const result = lib.borrowBook(id, name);
        const color = result.success ? 'green' : 'red';
        document.getElementById('borrowOutput').innerHTML = `<span style="color:${color}">${result.message}</span>`;
        document.getElementById('borrowId').value = '';
        document.getElementById('borrowerName').value = '';
    }

    function returnBook() {
        const id = parseInt(document.getElementById('returnId').value);
        if (isNaN(id)) {
            document.getElementById('returnOutput').innerHTML = '<span style="color:red">❌ Enter valid Book ID.</span>';
            return;
        }
        const result = lib.returnBook(id);
        const color = result.success ? 'green' : 'red';
        document.getElementById('returnOutput').innerHTML = `<span style="color:${color}">${result.message}</span>`;
        document.getElementById('returnId').value = '';
    }

    function showAllBooks() {
        const books = lib.getAllBooks();
        if (books.length === 0) {
            document.getElementById('displayArea').innerHTML = '<p style="text-align:center; color:#718096;">📭 No books in library. Add some books to get started!</p>';
        } else {
            displayBookList(books, document.getElementById('displayArea'), '📚 All Books in Catalog');
        }
        hideAllSections();
    }

    function showAvailableBooks() {
        const books = lib.getAvailableBooks();
        if (books.length === 0) {
            document.getElementById('displayArea').innerHTML = '<p style="text-align:center; color:#718096;">📭 No books available at the moment.</p>';
        } else {
            displayBookList(books, document.getElementById('displayArea'), '✅ Available Books');
        }
        hideAllSections();
    }

    function showBorrowedBooks() {
        const books = lib.getBorrowedBooks();
        if (books.length === 0) {
            document.getElementById('displayArea').innerHTML = '<p style="text-align:center; color:#718096;">📭 No books currently borrowed.</p>';
        } else {
            displayBookList(books, document.getElementById('displayArea'), '📤 Borrowed Books');
        }
        hideAllSections();
    }

    function showBrowser() {
        hideAllSections();
        const catalog = lib.catalog;
        if (!catalog.head) {
            document.getElementById('displayArea').innerHTML = '<p style="text-align:center;">📭 No books in catalog. Add some first.</p>';
            return;
        }
        const updateBrowserDisplay = () => {
            const book = catalog.current.book;
            const statusClass = book.isAvailable ? 'status-available' : 'status-borrowed';
            const statusText = book.isAvailable ? 'Available' : 'Borrowed';
            document.getElementById('displayArea').innerHTML = `
                <div class="browser-card">
                    <h3>🔁 Browse Catalog</h3>
                    <div class="book-detail">
                        <p><strong>📌 ID:</strong> ${book.bookID}</p>
                        <p><strong>📖 Title:</strong> "${book.title}"</p>
                        <p><strong>✍️ Author:</strong> ${book.author}</p>
                        <p><strong>📚 Genre:</strong> ${book.genre}</p>
                        <p><strong>📊 Status:</strong> <span class="status-badge ${statusClass}">${statusText}</span></p>
                    </div>
                    <div style="display:flex; gap:15px; justify-content:center; margin-top:20px;">
                        <button class="btn-primary" onclick="browserPrev()">◀ Previous</button>
                        <button class="btn-primary" onclick="browserNext()">Next ▶</button>
                        <button class="btn-primary" onclick="hideBrowser()">Close</button>
                    </div>
                </div>
            `;
        };
        window.browserUpdate = updateBrowserDisplay;
        updateBrowserDisplay();
    }

    function browserNext() {
        lib.catalog.next();
        if (window.browserUpdate) window.browserUpdate();
    }

    function browserPrev() {
        lib.catalog.prev();
        if (window.browserUpdate) window.browserUpdate();
    }

    function hideBrowser() {
        document.getElementById('displayArea').innerHTML = '<p style="text-align:center;">✨ Browser closed. Use menu to reopen.</p>';
        hideAllSections();
    }

    function showWaitingList() {
        const entries = lib.getWaitingList();
        if (entries.length === 0) {
            document.getElementById('displayArea').innerHTML = '<p style="text-align:center;">⏳ Waiting list is empty.</p>';
        } else {
            let html = `<h3>⏳ Waiting List (${entries.length} users waiting)</h3>`;
            html += `<table><thead><tr><th>Book Title</th><th>Requested By</th></tr></thead><tbody>`;
            entries.forEach(e => {
                html += `<tr><td><strong>${e.book.title}</strong></td><td>${e.userName}</td></tr>`;
            });
            html += `</tbody></table>`;
            document.getElementById('displayArea').innerHTML = html;
        }
        hideAllSections();
    }

    function loadSampleData() {
        if (confirm('📚 Load sample books? This will add 4 professional programming books to your library.')) {
            lib.loadSampleData();
            document.getElementById('displayArea').innerHTML = '<p style="color:green; text-align:center;">✅ 4 sample books loaded successfully!</p>';
            hideAllSections();
        }
    }
    
    function clearAllData() {
        if (confirm('⚠️ WARNING: This will delete ALL books and waiting list data. This action cannot be undone. Are you sure?')) {
            lib.clearAllData();
            document.getElementById('displayArea').innerHTML = '<p style="color:red; text-align:center;">🗑️ All data cleared! Refreshing...</p>';
            setTimeout(() => location.reload(), 1500);
        }
    }

    function hideAllSections() {
        document.querySelectorAll('.section').forEach(sec => sec.style.display = 'none');
    }
</script>
</body>
</html>
